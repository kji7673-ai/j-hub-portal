# J-Hub Portal 환경변수 설정 파일 (예시)
# 이 파일을 .env로 복사하여 실제 값을 입력하세요:  cp .env.example .env

# Flask 세션 비밀키 (FUNC-05: 서버 재시작 시 세션 유지를 위해 고정값 사용)
FLASK_SECRET_KEY=여기에_고유한_랜덤_문자열_입력

# Supabase 데이터베이스 연결 (비밀번호 변경 기능에 필요)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-or-service-key

# 서울시 정보몽땅 API (EXT-01: 실시간 공고 크롤링)
SEOUL_API_KEY=발급받은_API_KEY

# 네이버 밴드 API (EXT-04: 주간보고서 자동 수집)
BAND_ACCESS_TOKEN=발급받은_ACCESS_TOKEN
