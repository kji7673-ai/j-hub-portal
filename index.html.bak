        <!-- MODE 3: WEEKLY REPORT (독립 파일에서 로드 — 빌드 수정에 영향받지 않음) -->
        <div id="view-weekly" class="page-view">
            <!-- Weekly Report Content (Admin View) -->
            <div id="weekly-admin-view" style="display: block;">
                <div style="background: #fafafc; border: 1px solid var(--accent); border-left: 4px solid #0066cc; padding: 6px 10px; margin-bottom: 8px; display: flex; justify-content: space-between; align-items: center;">
                    <h2 style="margin: 0; font-size: 13px; font-weight: 600;">
                        [승인 대기] 통합 주간 보고서 초안
                    </h2>
                    <span style="font-size: 11px; font-weight: 400; color: #555; background: #e5e5ea; padding: 2px 6px; border-radius: 4px;">수집 완료: 7월 4주차 금요일 17:00</span>
                </div>

                <!-- Generated Draft Preview -->
                <div class="card" style="border: 2px dashed #ccc; padding: 8px; background: #fff; margin-bottom: 8px;">
                    <div style="width: 100%; height: 1600px; overflow: hidden; border: 1px solid #e0e0e0; border-radius: 8px;">
                        <iframe src="./reports/2026년 7월 4주차 주간 보고.html?v=2" style="width: 100%; height: 100%; border: none;"></iframe>
                    </div>
                </div>

                <!-- ============================================ -->
                <!-- 📷 본부별 주간 계획서 이미지 업로드 -->
                <!-- ============================================ -->
                <div class="card" style="background: #fff; border: 1px solid var(--accent); margin-top: 16px; margin-bottom: 16px;">
                    <div class="card-header">
                        <div class="card-title">📷 본부별 주간 계획서 / 회의록 이미지 업로드</div>
                        <span class="chip blue" id="upload-week-label"></span>
                    </div>
                    <div style="padding: 16px;">
                        <p style="font-size: 13px; color: #555; margin-top: 0; margin-bottom: 16px;">
                            각 본부 주간 계획서, 회의록 등을 이미지로 업로드하세요. <strong>다중 선택</strong> 가능합니다.<br>
                            <span style="color: #7a7a7a; font-size: 12px;">허용 형식: JPG, PNG, GIF, WEBP, PDF | 최대 10MB/건 | 로그인된 이름으로 업로더가 자동 기록됩니다.</span>
                        </p>

                        <!-- 드래그 앤 드롭 영역 -->
                        <div id="upload-drop-zone" style="
                            border: 2px dashed #d2d2d7; 
                            border-radius: 8px; 
                            padding: 40px 20px; 
                            text-align: center; 
                            cursor: pointer;
                            transition: all 0.2s;
                            background: #fafafc;
                            margin-bottom: 16px;
                        " onclick="document.getElementById('upload-input').click()">
                            <div style="font-size: 40px; margin-bottom: 8px;">📁</div>
                            <div style="font-size: 15px; font-weight: 600; color: #1d1d1f;">클릭하여 파일 선택 또는 여기에 드래그</div>
                            <div style="font-size: 12px; color: #7a7a7a; margin-top: 4px;">Ctrl / Cmd 키로 다중 선택 가능</div>
                        </div>
                        <input type="file" id="upload-input" multiple accept="image/*,.pdf" style="display: none;">

                        <!-- 선택된 파일 미리보기 -->
                        <div id="upload-preview" style="display: none; margin-bottom: 16px;">
                            <div style="font-size: 13px; font-weight: 600; margin-bottom: 8px;">선택된 파일:</div>
                            <div id="upload-preview-list" style="display: flex; flex-wrap: wrap; gap: 8px;"></div>
                        </div>

                        <!-- 업로드 버튼 + 상태 -->
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div id="upload-status" style="font-size: 13px; color: #555;"></div>
                            <button id="upload-btn" onclick="doUpload()" style="
                                background: #0066cc; color: white; border: none; 
                                padding: 10px 24px; border-radius: 6px; 
                                font-weight: bold; cursor: pointer; 
                                display: none;
                            ">📤 업로드 하기</button>
                        </div>
                    </div>
                </div>

                <!-- 📸 업로드된 이미지 갤러리 -->
                <div class="card" style="background: #fff; border: 1px solid var(--accent); margin-bottom: 16px;">
                    <div class="card-header" style="cursor: pointer;" onclick="loadUploadedImages()">
                        <div class="card-title">📸 업로드된 이미지 열람</div>
                        <button class="chip" onclick="event.stopPropagation(); loadUploadedImages()">새로고침</button>
                    </div>
                    <div id="gallery-container" style="padding: 16px;">
                        <p style="color: #999; text-align: center; padding: 20px;">로딩 중...</p>
                    </div>
                </div>

                <script>
                // --- 업로드 기능 ---
                const uploadInput = document.getElementById('upload-input');
                const dropZone = document.getElementById('upload-drop-zone');
                const previewDiv = document.getElementById('upload-preview');
                const previewList = document.getElementById('upload-preview-list');
                const uploadBtn = document.getElementById('upload-btn');
                const uploadStatus = document.getElementById('upload-status');

                // 주차 라벨
                const now = new Date();
                const onejan = new Date(now.getFullYear(),0,1);
                const weekNum = Math.ceil((((now - onejan) / 86400000) + onejan.getDay()+1)/7);
                const weekLabel = document.getElementById('upload-week-label');
                if (weekLabel) weekLabel.textContent = now.getFullYear() + '-W' + String(weekNum).padStart(2,'0');

                // 드래그 앤 드롭
                dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.style.borderColor = '#0066cc'; dropZone.style.background = '#e8f0fe'; });
                dropZone.addEventListener('dragleave', e => { e.preventDefault(); dropZone.style.borderColor = '#d2d2d7'; dropZone.style.background = '#fafafc'; });
                dropZone.addEventListener('drop', e => {
                    e.preventDefault();
                    dropZone.style.borderColor = '#d2d2d7'; dropZone.style.background = '#fafafc';
                    uploadInput.files = e.dataTransfer.files;
                    showPreview(e.dataTransfer.files);
                });

                uploadInput.addEventListener('change', () => showPreview(uploadInput.files));

                function showPreview(files) {
                    if (!files || files.length === 0) { previewDiv.style.display = 'none'; uploadBtn.style.display = 'none'; return; }
                    previewList.innerHTML = '';
                    let totalSize = 0;
                    for (let f of files) {
                        totalSize += f.size;
                        const item = document.createElement('div');
                        item.style.cssText = 'background:#f5f5f7; border:1px solid #e0e0e0; padding:6px 10px; border-radius:4px; font-size:12px; display:flex; align-items:center; gap:6px;';
                        const isImg = f.type.startsWith('image/');
                        item.innerHTML = (isImg ? '🖼️' : '📄') + ' <span>' + f.name + '</span> <span style="color:#999;">(' + (f.size/1024).toFixed(0) + 'KB)</span>';
                        previewList.appendChild(item);
                    }
                    previewDiv.style.display = 'block';
                    uploadBtn.style.display = 'inline-block';
                    uploadStatus.textContent = files.length + '건 선택됨 (총 ' + (totalSize/1024/1024).toFixed(1) + 'MB)';
                }

                async function doUpload() {
                    const files = uploadInput.files;
                    if (!files || files.length === 0) return;

                    uploadBtn.disabled = true;
                    uploadBtn.textContent = '업로드 중...';
                    uploadBtn.style.opacity = '0.6';

                    const formData = new FormData();
                    for (let f of files) { formData.append('files', f); }

                    try {
                        const resp = await fetch('/api/upload', { method: 'POST', body: formData });
                        const data = await resp.json();
                        if (data.success) {
                            uploadStatus.innerHTML = '<span style="color:#00cc66; font-weight:bold;">✅ ' + data.message + '</span>';
                            uploadInput.value = '';
                            previewDiv.style.display = 'none';
                            uploadBtn.style.display = 'none';
                            loadUploadedImages();
                        } else {
                            uploadStatus.innerHTML = '<span style="color:red;">❌ ' + data.message + '</span>';
                        }
                    } catch(e) {
                        uploadStatus.innerHTML = '<span style="color:red;">❌ 서버 통신 오류</span>';
                    }
                    uploadBtn.disabled = false;
                    uploadBtn.textContent = '📤 업로드 하기';
                    uploadBtn.style.opacity = '1';
                }

                // --- 갤러리 로드 ---
                async function loadUploadedImages() {
                    const container = document.getElementById('gallery-container');
                    try {
                        const resp = await fetch('/api/uploads');
                        const data = await resp.json();
                        if (!data || data.length === 0) {
                            container.innerHTML = '<p style="color:#999; text-align:center; padding:20px;">아직 업로드된 파일이 없습니다.</p>';
                            return;
                        }
                        let html = '<table style="width:100%; border-collapse:collapse; font-size:14px;">';
                        html += '<tr style="border-bottom:2px solid #000;"><th style="text-align:left; padding:8px;">파일명</th><th style="text-align:left; padding:8px;">업로더</th><th style="text-align:left; padding:8px;">업로드 일시</th><th style="text-align:left; padding:8px;">주차</th><th style="padding:8px;">미리보기</th></tr>';
                        data.forEach(item => {
                            const isImage = /\.(jpg|jpeg|png|gif|webp|bmp)$/i.test(item.filename);
                            const previewBtn = isImage 
                                ? '<button onclick="previewImage(\\'' + '/api/uploads/' + item.week + '/' + item.filename + '\\')" style="background:#0066cc;color:#fff;border:none;padding:4px 10px;border-radius:4px;cursor:pointer;font-size:12px;">보기</button>'
                                : '<span style="color:#999; font-size:12px;">PDF</span>';
                            html += '<tr style="border-bottom:1px solid #e0e0e0;">';
                            html += '<td style="padding:8px; font-size:13px;">' + (item.original_name || item.filename) + '</td>';
                            html += '<td style="padding:8px;"><strong>' + item.uploader + '</strong></td>';
                            html += '<td style="padding:8px; color:#7a7a7a;">' + item.timestamp + '</td>';
                            html += '<td style="padding:8px;"><span class="chip">' + item.week + '</span></td>';
                            html += '<td style="padding:8px; text-align:center;">' + previewBtn + '</td>';
                            html += '</tr>';
                        });
                        html += '</table>';
                        container.innerHTML = html;
                    } catch(e) {
                        container.innerHTML = '<p style="color:red;">데이터 로드 실패</p>';
                    }
                }

                function previewImage(src) {
                    const overlay = document.createElement('div');
                    overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.85);z-index:99999;display:flex;justify-content:center;align-items:center;cursor:pointer;';
                    overlay.onclick = () => overlay.remove();
                    overlay.innerHTML = '<img src="' + src + '" style="max-width:90vw; max-height:90vh; object-fit:contain; border-radius:4px; box-shadow:0 8px 32px rgba(0,0,0,0.5);">' 
                        + '<div style="position:fixed;top:20px;right:20px;color:#fff;font-size:32px;cursor:pointer;" onclick="this.parentElement.remove()">✕</div>';
                    document.body.appendChild(overlay);
                }

                // 페이지 진입 시 자동 로드
                setTimeout(loadUploadedImages, 500);
                </script>

                <!-- 비공개 1:1 다이렉트 피드백 (Direct Drop-box) -->
                <div class="card" style="background: #fafafc; border: 1px solid var(--accent); margin-top: 16px;">
                    <div class="card-header">
                        <div class="card-title">💡 실무 아이디어 & 제안 직통함 (Direct Drop-box)</div>
                    </div>
                    <div style="padding: 16px;">
                        <p style="font-size: 13px; color: #555; margin-top: 0; margin-bottom: 16px;">
                            주간회의록을 읽고 떠오른 아이디어나 크로스 체크 사항을 남겨주세요. 
                            본 의견은 게시판에 공개되지 않으며 <strong>대표이사님께 1:1로 직접 전달</strong>됩니다.
                        </p>
                        <input type="text" id="fb-project" placeholder="관련 안건명 또는 프로젝트명" style="width: 100%; padding: 10px; margin-bottom: 12px; border: 1px solid #ccc; border-radius: 6px; box-sizing: border-box; font-family: inherit;">
                        <textarea id="fb-content" placeholder="자유롭게 의견을 남겨주세요..." style="width: 100%; padding: 10px; margin-bottom: 12px; border: 1px solid #ccc; border-radius: 6px; min-height: 100px; box-sizing: border-box; font-family: inherit;"></textarea>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <label style="font-size: 13px; color: #333; cursor: pointer;">
                                <input type="checkbox" id="fb-anonymous"> 익명으로 전달하기
                            </label>
                            <button onclick="submitFeedback()" style="background: #0066cc; color: white; border: none; padding: 10px 24px; border-radius: 6px; font-weight: bold; cursor: pointer;">의견 보내기</button>
                        </div>
                        <div id="fb-status" style="margin-top: 12px; font-size: 14px; font-weight: bold; display: none;"></div>
                    </div>
                </div>

                <script>
                async function submitFeedback() {
                    const project = document.getElementById('fb-project').value.trim();
                    const content = document.getElementById('fb-content').value.trim();
                    const isAnonymous = document.getElementById('fb-anonymous').checked;
                    const statusEl = document.getElementById('fb-status');

                    if (!content) {
                        statusEl.style.color = 'red';
                        statusEl.innerText = '피드백 내용을 입력해주세요.';
                        statusEl.style.display = 'block';
                        return;
                    }

                    try {
                        const response = await fetch('/api/feedback', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({
                                project_name: project,
                                content: content,
                                is_anonymous: isAnonymous
                            })
                        });
                        const data = await response.json();
                        if (data.success) {
                            document.getElementById('fb-project').value = '';
                            document.getElementById('fb-content').value = '';
                            document.getElementById('fb-anonymous').checked = false;
                            statusEl.style.color = '#00cc66';
                            statusEl.innerText = '✅ 대표이사님께 안전하게 직접 전달되었습니다!';
                            statusEl.style.display = 'block';
                            setTimeout(() => { statusEl.style.display = 'none'; }, 5000);
                        } else {
                            statusEl.style.color = 'red';
                            statusEl.innerText = '오류: ' + data.message;
                            statusEl.style.display = 'block';
                        }
                    } catch (e) {
                        statusEl.style.color = 'red';
                        statusEl.innerText = '서버 통신 오류가 발생했습니다.';
                        statusEl.style.display = 'block';
                    }
                }
                </script>

                <!-- ============================================ -->
                <!-- 📋 제출 현황 대시보드 -->
                <!-- ============================================ -->
                <div class="card" style="background: #fff; border: 1px solid var(--accent); margin-top: 24px; margin-bottom: 16px;">
                    <div class="card-header">
                        <div class="card-title">📋 본부별 제출 현황</div>
                        <button class="chip" onclick="loadSubmissionStatus()" style="cursor:pointer;">새로고침</button>
                    </div>
                    <div id="submission-dashboard" style="padding: 16px;">
                        <p style="color:#999; text-align:center;">로딩 중...</p>
                    </div>
                </div>

                <script>
                async function loadSubmissionStatus() {
                    const container = document.getElementById('submission-dashboard');
                    try {
                        const resp = await fetch('/api/uploads');
                        const data = await resp.json();
                        
                        const depts = ['디자인본부', '도시개발본부', '도시계획본부', '전략기획본부', 'CM감리본부', '경영관리본부'];
                        const now = new Date();
                        const onejan = new Date(now.getFullYear(),0,1);
                        const wn = Math.ceil((((now - onejan) / 86400000) + onejan.getDay()+1)/7);
                        const currentWeek = now.getFullYear() + '-W' + String(wn).padStart(2,'0');
                        
                        // 현재 주차 업로드 필터
                        const thisWeek = Array.isArray(data) ? data.filter(d => d.week === currentWeek) : [];
                        
                        // 업로더별 그룹
                        const byUploader = {};
                        thisWeek.forEach(item => {
                            if (!byUploader[item.uploader]) byUploader[item.uploader] = [];
                            byUploader[item.uploader].push(item);
                        });
                        
                        let html = '<table style="width:100%; border-collapse:collapse; font-size:14px;">';
                        html += '<tr style="border-bottom:2px solid #000;"><th style="text-align:left;padding:10px;">업로더</th><th style="text-align:center;padding:10px;">파일 수</th><th style="text-align:left;padding:10px;">최근 업로드</th><th style="text-align:center;padding:10px;">상태</th></tr>';
                        
                        const uploaders = Object.keys(byUploader);
                        if (uploaders.length === 0) {
                            html += '<tr><td colspan="4" style="padding:20px; text-align:center; color:#999;">이번 주차 (' + currentWeek + ') 아직 업로드된 파일이 없습니다.</td></tr>';
                        } else {
                            uploaders.forEach(name => {
                                const files = byUploader[name];
                                const latest = files.sort((a,b) => b.timestamp.localeCompare(a.timestamp))[0];
                                html += '<tr style="border-bottom:1px solid #e0e0e0;">';
                                html += '<td style="padding:10px;"><strong>' + name + '</strong></td>';
                                html += '<td style="padding:10px; text-align:center;">' + files.length + '건</td>';
                                html += '<td style="padding:10px; color:#7a7a7a;">' + latest.timestamp + '</td>';
                                html += '<td style="padding:10px; text-align:center;"><span style="color:#00cc66; font-weight:bold;">✅ 제출</span></td>';
                                html += '</tr>';
                            });
                        }
                        html += '</table>';
                        container.innerHTML = html;
                    } catch(e) {
                        container.innerHTML = '<p style="color:red;">로드 실패</p>';
                    }
                }
                setTimeout(loadSubmissionStatus, 800);
                </script>

                <!-- ============================================ -->
                <!-- 🚀 최종 승인 및 발행 (실제 파이프라인 연결) -->
                <!-- ============================================ -->
                <div id="weekly-publish-actions" style="margin-top: 32px; text-align: center; border: 2px solid var(--accent); padding: 32px; background: #fafafc;">
                    <h3 style="margin: 0 0 8px 0; font-size: 16px; text-transform: uppercase; letter-spacing: -0.5px;">최종 승인 및 발행</h3>
                    <p style="font-size: 13px; color: #888; margin: 0 0 20px 0;">
                        승인 버튼을 누르면 법규 크롤링 → 기사 수집 → 보고서 파싱 → 포털 재빌드가 순차 실행됩니다.<br>
                        <strong>대표이사 전용</strong> — 약 30초~1분 소요
                    </p>
                    <button id="publish-btn" onclick="publishWeeklyReport()" style="
                        background: #0066cc; color: white; border: none; 
                        padding: 16px 48px; font-size: 18px; font-weight: bold; 
                        cursor: pointer; box-shadow: 0 4px 12px rgba(0,102,204,0.3);
                        transition: all 0.3s;
                    ">🚀 최종 승인 및 발행 (Publish)</button>
                    
                    <!-- 실행 로그 표시 영역 -->
                    <div id="publish-log-area" style="display: none; margin-top: 20px; text-align: left;">
                        <div style="font-size: 13px; font-weight: 600; margin-bottom: 8px;">⚙️ 파이프라인 실행 로그:</div>
                        <pre id="publish-log" style="
                            background: #1d1d1f; color: #00cc66; 
                            padding: 16px; font-size: 12px; 
                            max-height: 300px; overflow-y: auto;
                            font-family: 'SF Mono', 'Menlo', monospace;
                            white-space: pre-wrap; word-break: break-all;
                        "></pre>
                    </div>
                </div>
            </div>
            
            <script>
                function unlockWeekly() {
                    document.getElementById("weekly-lock-screen").style.display = "none";
                    document.getElementById("weekly-admin-view").style.display = "block";
                    window.scrollTo(0,0);
                }

                async function publishWeeklyReport() {
                    const btn = document.getElementById('publish-btn');
                    const logArea = document.getElementById('publish-log-area');
                    const logPre = document.getElementById('publish-log');
                    
                    btn.disabled = true;
                    btn.textContent = '⏳ 파이프라인 실행 중...';
                    btn.style.opacity = '0.6';
                    btn.style.cursor = 'not-allowed';
                    logArea.style.display = 'block';
                    logPre.textContent = '파이프라인 시작 대기 중...\n';

                    try {
                        const resp = await fetch('/api/publish', { method: 'POST' });
                        const data = await resp.json();
                        
                        if (!data.success) {
                            logPre.textContent = '❌ ' + data.message;
                            btn.disabled = false;
                            btn.textContent = '🚀 최종 승인 및 발행 (Publish)';
                            btn.style.opacity = '1';
                            btn.style.cursor = 'pointer';
                            return;
                        }

                        // 폴링으로 진행 상황 실시간 표시
                        const pollInterval = setInterval(async () => {
                            try {
                                const sr = await fetch('/api/publish/status');
                                const sd = await sr.json();
                                logPre.textContent = sd.log || '실행 중...';
                                logPre.scrollTop = logPre.scrollHeight;
                                
                                if (!sd.running) {
                                    clearInterval(pollInterval);
                                    if (sd.result === 'success') {
                                        btn.textContent = '✅ 포털 업데이트 완료!';
                                        btn.style.background = '#00cc66';
                                        btn.style.boxShadow = 'none';
                                        setTimeout(() => {
                                            if (confirm('포털이 성공적으로 갱신되었습니다. 페이지를 새로고침하시겠습니까?')) {
                                                location.reload();
                                            }
                                        }, 1000);
                                    } else {
                                        btn.textContent = '⚠️ 일부 실패 — 로그 확인';
                                        btn.style.background = '#e30000';
                                    }
                                    setTimeout(() => {
                                        btn.disabled = false;
                                        btn.textContent = '🚀 최종 승인 및 발행 (Publish)';
                                        btn.style.background = '#0066cc';
                                        btn.style.opacity = '1';
                                        btn.style.cursor = 'pointer';
                                        btn.style.boxShadow = '0 4px 12px rgba(0,102,204,0.3)';
                                    }, 10000);
                                }
                            } catch(e) { /* ignore polling errors */ }
                        }, 2000);

                    } catch(e) {
                        logPre.textContent = '🚨 서버 통신 오류: ' + e.message;
                        btn.disabled = false;
                        btn.textContent = '🚀 최종 승인 및 발행 (Publish)';
                        btn.style.opacity = '1';
                        btn.style.cursor = 'pointer';
                    }
                }
            </script>
        </div>
        
        <!-- MODE 4: MASTER VIEW (제안함) -->
        </div>

        <!-- MODE 4: MASTER (독립 파일에서 로드 — 빌드 수정에 영향받지 않음) -->
        <div id="view-master" class="page-view">
             <div style="background: #fafafc; border: 1px solid var(--accent); border-left: 4px solid #800080; padding: 12px 16px; margin-bottom: 16px;">
                <h2 style="margin: 0; font-size: 16px; font-weight: 600;">📥 접수된 실무 아이디어 및 제안 (Master Only)</h2>
                <p style="margin: 4px 0 0 0; font-size: 13px; color: #555;">직원들이 보낸 피드백이 실시간으로 여기에 누적됩니다.</p>
                <button onclick="loadFeedbacks()" style="margin-top:12px; background:#800080; color:#fff; border:none; padding:6px 12px; border-radius:4px; cursor:pointer; font-weight:bold;">새로고침 (Reload)</button>
            </div>
            <div id="master-feedbacks-container">
                <!-- Feedbacks will be rendered here -->
            </div>

<script>
// BUG-04 FIX: XSS 방지 이스케이프 함수
function escapeHTML(str) {
    if (!str) return '';
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
}

async function loadFeedbacks() {
    try {
        const resp = await fetch('/api/feedbacks');
        const data = await resp.json();
        const container = document.getElementById('master-feedbacks-container');
        if (!data || data.length === 0) {
            container.innerHTML = '<p style="color:#999; text-align:center; padding:40px;">아직 접수된 제안이 없습니다.</p>';
            return;
        }
        container.innerHTML = data.reverse().map(fb => `
            <div style="background:#fff; border:1px solid #e5e5ea; padding:16px; margin-bottom:12px;">
                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:8px;">
                    <strong style="font-size:14px;">${escapeHTML(fb.author)}</strong>
                    <span style="font-size:12px; color:#999;">${escapeHTML(fb.timestamp)}</span>
                </div>
                ${fb.project_name ? '<div style="font-size:12px; color:#0066cc; margin-bottom:4px;">📌 ' + escapeHTML(fb.project_name) + '</div>' : ''}
                <p style="margin:0; font-size:14px; line-height:1.6;">${escapeHTML(fb.content)}</p>
            </div>
        `).join('');
    } catch(e) {
        document.getElementById('master-feedbacks-container').innerHTML = '<p style="color:red;">피드백 로드 실패</p>';
    }
}

// BUG-05 FIX: 탭 진입 시 자동 로드
setTimeout(loadFeedbacks, 500);
</script>

        </div>
    </div>
    
    <script>
